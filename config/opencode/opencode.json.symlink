      },
      "models": {
        "qwen3-coder:30b": {
          "name": "Qwen3 Coder 30B"
        },
        "deepseek-r1:14b": {
          "name": "DeepSeek R1 14B"
        },
        "gpt-oss:20b": {
          "name": "GPT OSS 20B"
        }
      }
    }
  }
}
